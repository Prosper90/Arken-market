# RabbitMQ
RABBITMQ_URL=amqp://admin:admin@localhost:5672

# Auth
JWT_TOKEN_SECRET=your_jwt_secret_here

# Database
DB_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>

# Encryption
ENCRYPTION_KEY=your_encryption_key_here

# Polymarket
POLYMARKET_URL=https://gamma-api.polymarket.com
POLY_PRIVATE_KEY=0x_your_polymarket_private_key

# Email
FROM_EMAIL=your@email.com
FROM_NAME=YourAppName
EMAIL_HOST=smtp.gmail.com
EMAILPORT=587
EMAIL_PASSWORD=your_email_password
ADMIN_EMAIL=admin@yourapp.com

# SSL (set USE_SSL=true on production server)
USE_SSL=false
SSL_KEY_PATH=/path/to/privkey.pem
SSL_CERT_PATH=/path/to/fullchain.pem

# UMA Oracle (EVM/Arbitrum only)
UMA_OO_V3_ADDRESS=0x072819Bb43B50E7A251c64411e7aA362ce82803B
UMA_DEFAULT_BOND_TOKEN=0xaf88d065e77c8cC2239327C5EDb3A432268e5831
UMA_DEFAULT_BOND_AMOUNT=100000000
UMA_DISPUTE_WINDOW_SECS=7200

# AI Oracle
AI_ORACLE_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your_key_here
OPENAI_API_KEY=sk-your_openai_key_here
AI_ORACLE_CONFIDENCE_THRESHOLD=0.85

# App Config
PORT=3003
