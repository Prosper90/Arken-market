# RabbitMQ
RABBITMQ_URL=amqp://admin:admin@localhost:5672

# Telegram Bot
BOT_TOKEN=your_telegram_bot_token

# Auth
JWT_TOKEN_SECRET=your_jwt_secret_here

# Database
DB_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>

# Encryption
ENCRYPTION_KEY=your_encryption_key_here

# Solana
SOL_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_key
SOL_RPC_URL2=https://mainnet.helius-rpc.com/?api-key=your_helius_key_backup
SOLANA_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
USDT_MINT=Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB

# EVM (Arbitrum)
EVM_PRIVATE_KEY=your_evm_admin_private_key
USDC_ADDRESS=0xaf88d065e77c8cC2239327C5EDb3A432268e5831
ARB_RPC_URL=https://arb1.arbitrum.io/rpc
ARBISCANEXPLORER=https://arbiscan.io/tx/
ETHERSCAN_API_KEY=your_etherscan_api_key

# Solana Admin Wallet
SOLFLARE_PRIVATE_KEY=[1,2,3,...your_keypair_bytes...]

# Polymarket
POLYMARKET_URL=https://gamma-api.polymarket.com

# Email
FROM_EMAIL=your@email.com
FROM_NAME=YourAppName
EMAIL_HOST=smtp.gmail.com
EMAILPORT=587
EMAIL_PASSWORD=your_email_password
ADMIN_EMAIL=admin@yourapp.com

# SSL (set USE_SSL=true on production server)
USE_SSL=false
SSL_KEY_PATH=/path/to/privkey.pem
SSL_CERT_PATH=/path/to/fullchain.pem

# App Config
PORT=3002
CRYPTO_COMPARE_API_KEY=your_cryptocompare_api_key
